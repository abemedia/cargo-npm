#!/bin/sh

# Convert a Windows path to a POSIX path if cygpath is available (Git Bash / MSYS2).
to_posix() {
  if command -v cygpath >/dev/null 2>&1; then
    cygpath -u -- "$1"
  else
    printf '%s' "$1"
  fi
}

case "$1" in
  --version)
    echo "0.0.0-fake"
    ;;
  view)
    spec="$2"
    if [ -f "$FAKE_NPM_LOG" ]; then
      while IFS= read -r line; do
        name="${line%%	*}"
        rest="${line#*	}"
        ver="${rest%%	*}"
        if [ "${name}@${ver}" = "$spec" ]; then
          echo "$ver"
          exit 0
        fi
      done < "$FAKE_NPM_LOG"
    fi
    echo "npm error code E404" >&2
    exit 1
    ;;
  publish)
    case "$2" in
    *.tgz | *.tar.gz)
      json=$(tar -xzOf "$(to_posix "$2")" package/package.json 2>/dev/null)
      ;;
    *)
      json=$(cat "$(to_posix "$2")/package.json" 2>/dev/null)
      ;;
    esac
    pkg_name=$(printf '%s' "$json" | grep '"name"' | cut -d'"' -f4)
    pkg_ver=$(printf '%s' "$json" | grep '"version"' | cut -d'"' -f4)
    if [ -z "$pkg_name" ] || [ -z "$pkg_ver" ]; then
      echo "npm error: could not read package metadata from $2" >&2
      exit 1
    fi
    spec="${pkg_name}@${pkg_ver}"
    if [ -f "$FAKE_NPM_LOG" ]; then
      while IFS= read -r line; do
        logged_name="${line%%	*}"
        logged_rest="${line#*	}"
        logged_ver="${logged_rest%%	*}"
        if [ "${logged_name}@${logged_ver}" = "$spec" ]; then
          echo "npm error: cannot publish over the previously published versions." >&2
          exit 1
        fi
      done < "$FAKE_NPM_LOG"
    fi
    shift 2
    printf '%s\t%s\t%s\n' "$pkg_name" "$pkg_ver" "$*" >> "$FAKE_NPM_LOG"
    ;;
  *)
    echo "fake-npm: unexpected command: $1" >&2
    exit 2
    ;;
esac
